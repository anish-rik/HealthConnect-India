# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/healthconnect-india
DB_NAME=healthconnect-india

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRY=7d

# ABHA/ABDM Integration (V3)
# Register at https://sandbox.abdm.gov.in/ to get credentials
ABHA_CLIENT_ID=your-sandbox-client-id
ABHA_CLIENT_SECRET=your-sandbox-client-secret
ABDM_BASE_URL=https://dev.abdm.gov.in/api/hiecm/gateway/v3
ABDM_CM_ID=sbx
ABDM_USE_MOCK=true

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info
